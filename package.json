{
  "name": "gurunkit",
  "version": "0.0.0",
  "author": "Narakode <ibrahimalanshor6@gmail.com> (https://narakode.id)",
  "keywords": ["vue", "tailwindcss"],
  "homepage": "https://github.com/narakode/gurunkit",
  "license": "MIT",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/gurun-kit.umd.cjs",
  "module": "./dist/gurun-kit.js",
  "exports": {
    ".": {
      "import": "./dist/gurun-kit.js",
      "require": "./dist/gurun-kit.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "postcss": "^8.5.14",
    "prettier": "3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*.{vue,js,ts,css,md}": "prettier --write",
    "*.{vue,js,ts}": "eslint --cache --fix"
  },
  "peerDependencies": {
    "tailwind": "^4.0.0",
    "vue": "^3.5.34"
  }
}
